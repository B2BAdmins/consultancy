        .intro-text {
            max-width: 800px;
            margin: 0 auto 40px;
            text-align: center;
            font-size: 1.1em;
            color: #555;
        }
        
        /* Services Grid */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }
        
        .service-card {
            background: #f8f9fa;
            padding: 30px;
            border-radius: 8px;
            border-left: 4px solid #2A9D8F;
            transition: transform 0.3s;
        }
        
        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        /* Process Steps */
        .process-steps {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 40px;
        }
        
        .step {
            flex: 1;
            min-width: 200px;
            text-align: center;
            padding: 30px 20px;
            background: white;
            border-radius: 8px;
            position: relative;
        }
        
        .step-number {
            display: inline-block;
            width: 50px;
            height: 50px;
            background: #E76F51;
            color: white;
            border-radius: 50%;
            line-height: 50px;
            font-size: 1.3em;
            font-weight: bold;
            margin-bottom: 15px;
