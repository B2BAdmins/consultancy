            color: white;
            padding: 20px;
            text-align: left;
            font-size: 1.1em;
        }
        
        .industries-table td {
            padding: 20px;
            border-bottom: 1px solid #eee;
        }
        
        .industries-table tr:hover {
            background: #f8f9fa;
        }
        
        .industry-icon {
            font-size: 1.5em;
            margin-right: 10px;
        }
        
        /* Contact */
        .contact-info {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }
        
        .contact-info p {
            margin: 10px 0;
            font-size: 1.1em;
        }
        
        .contact-info strong {
            color: #1E3A5F;
        }
        
